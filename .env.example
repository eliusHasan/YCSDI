# Frontend values go in frontend/.env
VITE_API_URL=http://localhost:5000/api/v1

# Backend values go in backend/.env
NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://localhost:27017/ycsdi
CORS_ORIGIN=http://localhost:5173

# Auth
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Seed first admin via: npm run seed:admin --prefix backend
ADMIN_USER_ID=
ADMIN_PASSWORD=

# Cloudinary (used by backend/src/config/cloudinary.ts)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
